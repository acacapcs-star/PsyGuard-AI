import 'dart:math' as math;
import 'dart:ui' as ui;

import 'package:flutter/material.dart';
import 'package:flutter/scheduler.dart';
import 'package:flutter/services.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';

import '../theme/mood_theme_service.dart';

/// 氛圍飄落效果控制器。
/// 在任何地方（例如點擊飄浮 lii 球球時）呼叫 [play]，
/// 頁面上的 [MoodFallOverlay] 就會播放「一次」對應氛圍的飄落動畫。
class MoodFallController extends ChangeNotifier {
  int _playCount = 0;
  int get playCount => _playCount;

  /// 觸發一次飄落動畫（動畫播放中重複呼叫會重新開始）。
  void play() {
    _playCount++;
    notifyListeners();
  }
}

/// 飄落效果種類。
enum FallEffectType {
  none,
  snow, // ❄️ 冬 / 聖誕節 / 寒假：半透明水晶雪花
  leaves, // 🍁 秋：楓葉飄落
  petals, // 🌸 春：櫻花瓣飄落
  fireworks, // 🧧 過年：煙火升空綻放
  splash, // ☀️ 夏：水花飛濺
  treats, // 🏖️ 暑假：冰品飄落 + 水珠
}

/// 單顆粒子的參數（出生時隨機決定，之後不再改變）。
/// 一發煙火的參數。
class _Firework {
  _Firework({
    required this.delay,
    required this.x,
    required this.apexY,
    required this.riseTime,
    required this.burstDuration,
    required this.seed,
    required this.colorIndex,
    required this.sparkCount,
  });

  final double delay; // 發射延遲（秒）
  final double x; // 0~1 水平位置
  final double apexY; // 0~1 爆炸高度（越小越高）
  final double riseTime; // 升空秒數
  final double burstDuration; // 綻放持續秒數
  final int seed; // 火花軌跡的固定亂數種子
  final int colorIndex; // 主色
  final int sparkCount; // 火花數量
}

class _FallParticle {
  _FallParticle({
    required this.x,
    required this.delay,
    required this.duration,
    required this.size,
    required this.swayAmp,
    required this.swaySpeed,
    required this.swayPhase,
    required this.spinSpeed,
    required this.spinPhase,
    required this.imageIndex,
    required this.isFlake,
    required this.opacity,
  });

  final double x; // 0~1 相對水平位置
  final double delay; // 出生延遲（秒）
  final double duration; // 從畫面頂端落到底部所需秒數
  final double size; // 尺寸（圖片粒子代表目標寬度）
  final double swayAmp; // 左右飄移幅度
  final double swaySpeed; // 左右飄移速度
  final double swayPhase; // 飄移相位
  final double spinSpeed; // 自轉速度
  final double spinPhase; // 自轉起始角度
  final int imageIndex; // >=0 表示用第幾張圖；-1 表示不用圖片
  final bool isFlake; // 圖片載入失敗時的備援：程式畫六角雪花
  final double opacity; // 基礎透明度
}

/// 疊加在頁面上的一次性飄落動畫圖層。
/// IgnorePointer 包住不擋互動；沒有動畫在跑時是空白 widget，幾乎零成本。
class MoodFallOverlay extends StatefulWidget {
  const MoodFallOverlay({
    super.key,
    required this.controller,
    required this.effect,
    this.particleCount = 18,
    this.snowColor = const Color(0xFF5EC1E0), // Frozen 冰藍：小雪點與光暈用色
  });

  final MoodFallController controller;
  final FallEffectType effect;
  final int particleCount;
  final Color snowColor;

  @override
  State<MoodFallOverlay> createState() => _MoodFallOverlayState();
}

class _MoodFallOverlayState extends State<MoodFallOverlay>
    with SingleTickerProviderStateMixin {
  /// 雪：只用水晶系雪花，半透明 crystalization 質感。
  static const List<String> _snowAssets = [
    'assets/images/mood_snow_2.png', // 粉紫水晶
    'assets/images/mood_snow_5.png', // 發光水晶
    'assets/images/mood_snow_6.png', // 冰晶星芒（Frozen 風）
  ];

  /// 秋：楓葉。
  static const List<String> _leafAssets = [
    'assets/images/mood_leaf_1.png', // 鮮豔楓葉
    'assets/images/mood_leaf_2.png', // 水彩楓葉
  ];

  /// 春：櫻花。
  static const List<String> _petalAssets = [
    'assets/images/mood_petal_1.png', // 花瓣（常見）
    'assets/images/mood_petal_2.png', // 整朵櫻花（偶爾）
  ];

  /// 暑假：清涼冰品。
  static const List<String> _treatAssets = [
    'assets/images/mood_icecream.png',
    'assets/images/mood_sushi.png',
  ];

  late final Ticker _ticker;
  final math.Random _rng = math.Random();
  final List<_FallParticle> _particles = [];
  final List<_Firework> _fireworks = [];
  double _elapsed = 0;
  double _totalDuration = 0;
  int _seenPlayCount = 0;
  FallEffectType _playingEffect = FallEffectType.none;

  final Map<FallEffectType, List<ui.Image>> _imageCache = {};
  final Map<FallEffectType, Future<List<ui.Image>>> _imageFutures = {};

  @override
  void initState() {
    super.initState();
    _ticker = createTicker(_onTick);
    _seenPlayCount = widget.controller.playCount;
    widget.controller.addListener(_onControllerChanged);
  }

  @override
  void didUpdateWidget(covariant MoodFallOverlay oldWidget) {
    super.didUpdateWidget(oldWidget);
    if (oldWidget.controller != widget.controller) {
      oldWidget.controller.removeListener(_onControllerChanged);
      _seenPlayCount = widget.controller.playCount;
      widget.controller.addListener(_onControllerChanged);
    }
  }

  @override
  void dispose() {
    widget.controller.removeListener(_onControllerChanged);
    _ticker.dispose();
    for (final list in _imageCache.values) {
      for (final img in list) {
        img.dispose();
      }
    }
    super.dispose();
  }

  void _onControllerChanged() {
    if (widget.controller.playCount == _seenPlayCount) return;
    _seenPlayCount = widget.controller.playCount;
    _startOnce();
  }

  List<String> _assetsFor(FallEffectType effect) {
    switch (effect) {
      case FallEffectType.snow:
        return _snowAssets;
      case FallEffectType.leaves:
        return _leafAssets;
      case FallEffectType.petals:
        return _petalAssets;
      case FallEffectType.fireworks:
        return const []; // 煙火純程式繪製，不需素材
      case FallEffectType.splash:
        return const []; // 水花純程式繪製
      case FallEffectType.treats:
        return _treatAssets;
      case FallEffectType.none:
        return const [];
    }
  }

  /// 載入指定效果的圖片（各載一次，之後重複使用）。
  /// 任一張失敗就退回備援繪製，不會讓 App 掛掉。
  Future<List<ui.Image>> _ensureImagesLoaded(FallEffectType effect) {
    return _imageFutures.putIfAbsent(effect, () async {
      final list = <ui.Image>[];
      try {
        for (final asset in _assetsFor(effect)) {
          final data = await rootBundle.load(asset);
          final codec =
              await ui.instantiateImageCodec(data.buffer.asUint8List());
          final frame = await codec.getNextFrame();
          list.add(frame.image);
        }
        _imageCache[effect] = list;
        return list;
      } catch (_) {
        for (final img in list) {
          img.dispose();
        }
        _imageCache[effect] = const [];
        return const [];
      }
    });
  }

  Future<void> _startOnce() async {
    final effect = widget.effect;
    if (effect == FallEffectType.none) return;

    await _ensureImagesLoaded(effect);
    if (!mounted) return;

    _particles.clear();
    _fireworks.clear();
    _playingEffect = effect;
    switch (effect) {
      case FallEffectType.snow:
        _spawnSnow();
        break;
      case FallEffectType.leaves:
        _spawnLeaves();
        break;
      case FallEffectType.petals:
        _spawnPetals();
        break;
      case FallEffectType.fireworks:
        _spawnFireworks();
        break;
      case FallEffectType.splash:
        _spawnSplash(mixTreats: false);
        break;
      case FallEffectType.treats:
        _spawnSplash(mixTreats: true);
        break;
      case FallEffectType.none:
        return;
    }

    _totalDuration = 0;
    for (final p in _particles) {
      final end = p.delay + p.duration;
      if (end > _totalDuration) _totalDuration = end;
    }
    for (final f in _fireworks) {
      final end = f.delay + f.riseTime + f.burstDuration;
      if (end > _totalDuration) _totalDuration = end;
    }
    _totalDuration += 0.3;

    _ticker.stop();
    _elapsed = 0;
    if (_particles.isNotEmpty || _fireworks.isNotEmpty) {
      _ticker.start();
      setState(() {});
    }
  }

  void _spawnSnow() {
    final images = _imageCache[FallEffectType.snow] ?? const <ui.Image>[];
    final hasImages = images.isNotEmpty;

    for (int i = 0; i < widget.particleCount; i++) {
      final useImage = hasImages && _rng.nextDouble() < 0.65;
      final paintedFlake = !useImage && !hasImages && _rng.nextDouble() < 0.4;

      final double size;
      if (useImage) {
        size = 26 + _rng.nextDouble() * 30;
      } else if (paintedFlake) {
        size = 7 + _rng.nextDouble() * 9;
      } else {
        size = 2.5 + _rng.nextDouble() * 3.5;
      }

      _particles.add(_FallParticle(
        x: _rng.nextDouble(),
        delay: _rng.nextDouble() * 6.4, // 分批出生（間距拉開）
        duration: 7.0 + _rng.nextDouble() * 6.0, // 7~13 秒緩慢落地
        size: size,
        swayAmp: 12 + _rng.nextDouble() * 26,
        swaySpeed: 0.6 + _rng.nextDouble() * 1.2,
        swayPhase: _rng.nextDouble() * math.pi * 2,
        spinSpeed: useImage
            ? (_rng.nextDouble() - 0.5) * 1.6
            : (_rng.nextDouble() - 0.5) * 2.4,
        spinPhase: _rng.nextDouble() * math.pi * 2,
        imageIndex: useImage ? _rng.nextInt(images.length) : -1,
        isFlake: paintedFlake,
        opacity: 0.4 + _rng.nextDouble() * 0.25, // 半透明冰晶感
      ));
    }
  }

  void _spawnLeaves() {
    final images = _imageCache[FallEffectType.leaves] ?? const <ui.Image>[];
    final hasImages = images.isNotEmpty;

    for (int i = 0; i < widget.particleCount; i++) {
      _particles.add(_FallParticle(
        x: _rng.nextDouble(),
        delay: _rng.nextDouble() * 6.0,
        duration: 6.0 + _rng.nextDouble() * 5.0, // 6~11 秒，落葉比雪稍快
        size: hasImages
            ? 30 + _rng.nextDouble() * 32 // 楓葉 30~62px
            : 4 + _rng.nextDouble() * 4, // 備援小圓點
        swayAmp: 22 + _rng.nextDouble() * 34, // 左右飄得更開
        swaySpeed: 0.5 + _rng.nextDouble() * 1.0,
        swayPhase: _rng.nextDouble() * math.pi * 2,
        spinSpeed: (_rng.nextDouble() - 0.5) * 3.2, // 落葉翻滾感
        spinPhase: _rng.nextDouble() * math.pi * 2,
        imageIndex: hasImages ? _rng.nextInt(images.length) : -1,
        isFlake: false,
        opacity: 0.78 + _rng.nextDouble() * 0.2, // 楓葉不透明一些
      ));
    }
  }

  void _spawnPetals() {
    final images = _imageCache[FallEffectType.petals] ?? const <ui.Image>[];
    final hasImages = images.isNotEmpty;

    for (int i = 0; i < widget.particleCount; i++) {
      // 75% 花瓣、25% 整朵櫻花
      final idx = hasImages ? (_rng.nextDouble() < 0.75 ? 0 : 1) : -1;
      final isFlower = idx == 1;
      _particles.add(_FallParticle(
        x: _rng.nextDouble(),
        delay: _rng.nextDouble() * 6.0,
        duration: 8.0 + _rng.nextDouble() * 6.0, // 8~14 秒，最夢幻的慢
        size: !hasImages
            ? 3 + _rng.nextDouble() * 3
            : isFlower
                ? 26 + _rng.nextDouble() * 14 // 整朵花大一點
                : 14 + _rng.nextDouble() * 16, // 花瓣小巧
        swayAmp: 26 + _rng.nextDouble() * 30, // 花瓣飄得最遠
        swaySpeed: 0.5 + _rng.nextDouble() * 0.9,
        swayPhase: _rng.nextDouble() * math.pi * 2,
        spinSpeed: (_rng.nextDouble() - 0.5) * 1.8,
        spinPhase: _rng.nextDouble() * math.pi * 2,
        imageIndex: idx,
        isFlake: false,
        opacity: 0.8 + _rng.nextDouble() * 0.18,
      ));
    }
  }

  /// 水花飛濺；mixTreats = true 時混入冰品/壽司翻滾飄落（暑假）。
  void _spawnSplash({required bool mixTreats}) {
    final images = _imageCache[FallEffectType.treats] ?? const <ui.Image>[];
    final hasImages = mixTreats && images.isNotEmpty;

    // 水珠：數量多、掉得快，有打水仗的清涼感
    final dropCount = widget.particleCount * 2;
    for (int i = 0; i < dropCount; i++) {
      _particles.add(_FallParticle(
        x: _rng.nextDouble(),
        delay: _rng.nextDouble() * 3.0,
        duration: 1.4 + _rng.nextDouble() * 1.4, // 1.4~2.8 秒，快！
        size: 2.5 + _rng.nextDouble() * 3.0,
        swayAmp: 3 + _rng.nextDouble() * 8,
        swaySpeed: 1.0 + _rng.nextDouble() * 1.5,
        swayPhase: _rng.nextDouble() * math.pi * 2,
        spinSpeed: 0,
        spinPhase: 0,
        imageIndex: -1,
        isFlake: false,
        opacity: 0.5 + _rng.nextDouble() * 0.35,
      ));
    }
    if (hasImages) {
      // 冰品與壽司翻滾飄落
      final treatCount = (widget.particleCount * 0.6).round();
      for (int i = 0; i < treatCount; i++) {
        _particles.add(_FallParticle(
          x: _rng.nextDouble(),
          delay: _rng.nextDouble() * 4.0,
          duration: 5.0 + _rng.nextDouble() * 4.0,
          size: 34 + _rng.nextDouble() * 26,
          swayAmp: 14 + _rng.nextDouble() * 22,
          swaySpeed: 0.6 + _rng.nextDouble() * 1.0,
          swayPhase: _rng.nextDouble() * math.pi * 2,
          spinSpeed: (_rng.nextDouble() - 0.5) * 2.6,
          spinPhase: _rng.nextDouble() * math.pi * 2,
          imageIndex: _rng.nextInt(images.length),
          isFlake: false,
          opacity: 0.85 + _rng.nextDouble() * 0.15,
        ));
      }
    }
  }

  void _spawnFireworks() {
    for (int i = 0; i < 6; i++) {
      _fireworks.add(_Firework(
        delay: i * 0.55 + _rng.nextDouble() * 0.35, // 一發接一發
        x: 0.15 + _rng.nextDouble() * 0.7,
        apexY: 0.16 + _rng.nextDouble() * 0.28,
        riseTime: 0.9 + _rng.nextDouble() * 0.4,
        burstDuration: 1.3 + _rng.nextDouble() * 0.5,
        seed: _rng.nextInt(1 << 31),
        colorIndex: _rng.nextInt(5),
        sparkCount: 26 + _rng.nextInt(16),
      ));
    }
  }

  void _onTick(Duration elapsed) {
    final t = elapsed.inMicroseconds / 1e6;
    if (t >= _totalDuration) {
      _ticker.stop();
      setState(() {
        _particles.clear();
        _fireworks.clear();
        _elapsed = 0;
      });
      return;
    }
    setState(() => _elapsed = t);
  }

  @override
  Widget build(BuildContext context) {
    if (_particles.isEmpty && _fireworks.isEmpty) {
      return const SizedBox.shrink();
    }
    return IgnorePointer(
      child: RepaintBoundary(
        child: CustomPaint(
          size: Size.infinite,
          painter: _FallPainter(
            particles: _particles,
            fireworks: _fireworks,
            images: _imageCache[_playingEffect] ?? const [],
            elapsed: _elapsed,
            effect: _playingEffect,
            snowColor: widget.snowColor,
          ),
        ),
      ),
    );
  }
}

class _FallPainter extends CustomPainter {
  _FallPainter({
    required this.particles,
    required this.fireworks,
    required this.images,
    required this.elapsed,
    required this.effect,
    required this.snowColor,
  });

  final List<_FallParticle> particles;
  final List<_Firework> fireworks;
  final List<ui.Image> images;
  final double elapsed;
  final FallEffectType effect;
  final Color snowColor;

  static const Color _leafDotColor = Color(0xFFCC7A4A); // 楓葉備援暖橘
  static const Color _petalDotColor = Color(0xFFF4A7C0); // 櫻花備援粉
  static const Color _splashDotColor = Color(0xFF4FC3F7); // 水珠藍

  static const List<Color> _fwPalette = [
    Color(0xFFFF5A5A), // 喜氣紅
    Color(0xFFFFC44D), // 金
    Color(0xFFFF8FB7), // 粉
    Color(0xFFFFA94D), // 橘
    Color(0xFF7FE3FF), // 冰藍
  ];

  @override
  void paint(Canvas canvas, Size size) {
    if (effect == FallEffectType.fireworks) {
      _paintFireworks(canvas, size);
      return;
    }
    final fill = Paint()..style = PaintingStyle.fill;
    final stroke = Paint()
      ..style = PaintingStyle.stroke
      ..strokeCap = StrokeCap.round;
    final imagePaint = Paint()..filterQuality = FilterQuality.medium;
    final haloPaint = Paint()
      ..maskFilter = const MaskFilter.blur(BlurStyle.normal, 8);
    final baseColor = effect == FallEffectType.leaves
        ? _leafDotColor
        : effect == FallEffectType.petals
            ? _petalDotColor
            : (effect == FallEffectType.splash ||
                    effect == FallEffectType.treats)
                ? _splashDotColor
                : snowColor;

    for (final p in particles) {
      final local = elapsed - p.delay;
      if (local < 0) continue;
      final t = local / p.duration;
      if (t > 1) continue;

      final margin = p.imageIndex >= 0 ? p.size : 40.0;
      final y = -margin + (size.height + margin * 2) * t;
      final x = p.x * size.width +
          math.sin(local * p.swaySpeed * math.pi + p.swayPhase) * p.swayAmp;

      double alpha = p.opacity;
      if (t < 0.08) alpha *= t / 0.08;
      if (t > 0.85) alpha *= (1 - t) / 0.15;
      alpha = alpha.clamp(0.0, 1.0);

      if (p.imageIndex >= 0 && p.imageIndex < images.length) {
        final img = images[p.imageIndex];
        if (effect == FallEffectType.snow) {
          // 雪花：淡淡光暈墊底，淺色背景上也看得見
          haloPaint.color = baseColor.withValues(alpha: alpha * 0.14);
          canvas.drawCircle(Offset(x, y), p.size * 0.42, haloPaint);
        }
        final scale = p.size / img.width;
        canvas.save();
        canvas.translate(x, y);
        canvas.rotate(p.spinPhase + local * p.spinSpeed);
        canvas.scale(scale);
        imagePaint.color = Colors.white.withValues(alpha: alpha);
        canvas.drawImage(
          img,
          Offset(-img.width / 2, -img.height / 2),
          imagePaint,
        );
        canvas.restore();
      } else if (p.isFlake) {
        stroke
          ..color = baseColor.withValues(alpha: alpha)
          ..strokeWidth = p.size * 0.14;
        _drawFlake(canvas, Offset(x, y), p.size,
            p.spinPhase + local * p.spinSpeed, stroke);
      } else {
        fill.color = baseColor.withValues(alpha: alpha);
        canvas.drawCircle(Offset(x, y), p.size, fill);
      }
    }
  }

  void _paintFireworks(Canvas canvas, Size size) {
    final dot = Paint()..style = PaintingStyle.fill;
    final glow = Paint()
      ..maskFilter = const MaskFilter.blur(BlurStyle.normal, 6);

    for (final fw in fireworks) {
      final local = elapsed - fw.delay;
      if (local < 0) continue;
      final color = _fwPalette[fw.colorIndex % _fwPalette.length];
      final apex = Offset(fw.x * size.width, fw.apexY * size.height);

      if (local < fw.riseTime) {
        // ── 升空 ──
        final p = (local / fw.riseTime).clamp(0.0, 1.0);
        final eased = 1 - (1 - p) * (1 - p); // 減速上升
        final y = (size.height + 12) + (apex.dy - size.height - 12) * eased;
        final x = apex.dx + math.sin(local * 10) * 1.5;
        // 尾焰
        for (int k = 1; k <= 4; k++) {
          dot.color = color.withValues(alpha: 0.35 / k);
          canvas.drawCircle(Offset(x, y + k * 7.0), 2.0, dot);
        }
        glow.color = color.withValues(alpha: 0.5);
        canvas.drawCircle(Offset(x, y), 4.5, glow);
        dot.color = Colors.white.withValues(alpha: 0.95);
        canvas.drawCircle(Offset(x, y), 2.2, dot);
      } else if (local < fw.riseTime + fw.burstDuration) {
        // ── 綻放 ──
        final bt =
            ((local - fw.riseTime) / fw.burstDuration).clamp(0.0, 1.0);
        // 中心閃光（前 15%）
        if (bt < 0.15) {
          glow.color = Colors.white.withValues(alpha: (1 - bt / 0.15) * 0.8);
          canvas.drawCircle(apex, 16 * (1 - bt / 0.15), glow);
        }
        final rng = math.Random(fw.seed);
        final maxBase = size.shortestSide * 0.16;
        for (int k = 0; k < fw.sparkCount; k++) {
          final ang = rng.nextDouble() * math.pi * 2;
          final maxR = maxBase * (0.6 + rng.nextDouble() * 0.8);
          final d = maxR * (1 - (1 - bt) * (1 - bt)); // 減速擴散
          final droop = 30 * bt * bt; // 重力下垂
          final pos = apex +
              Offset(math.cos(ang) * d, math.sin(ang) * d + droop);
          // 閃爍淡出
          double a = math.pow(1 - bt, 1.2).toDouble();
          a *= 0.7 + 0.3 * math.sin(bt * 28 + k * 1.7);
          if (a <= 0.02) continue;
          final c = Color.lerp(Colors.white, color, (bt * 2).clamp(0.0, 1.0))!;
          dot.color = c.withValues(alpha: a.clamp(0.0, 1.0));
          canvas.drawCircle(pos, 2.2 * (1 - bt * 0.55), dot);
        }
      }
    }
  }

  /// 備援用：程式畫的六角雪花。
  void _drawFlake(
      Canvas canvas, Offset center, double r, double rotation, Paint paint) {
    canvas.save();
    canvas.translate(center.dx, center.dy);
    canvas.rotate(rotation);
    for (int i = 0; i < 6; i++) {
      final angle = i * math.pi / 3;
      final dir = Offset(math.cos(angle), math.sin(angle));
      canvas.drawLine(Offset.zero, dir * r, paint);
      for (final frac in const [0.55, 0.8]) {
        final base = dir * (r * frac);
        final branchLen = r * (frac == 0.55 ? 0.30 : 0.22);
        for (final side in const [1.0, -1.0]) {
          final branchAngle = angle + side * math.pi / 5;
          final end = base +
              Offset(math.cos(branchAngle), math.sin(branchAngle)) * branchLen;
          canvas.drawLine(base, end, paint);
        }
      }
    }
    canvas.restore();
  }

  @override
  bool shouldRepaint(_FallPainter old) =>
      old.elapsed != elapsed || old.particles != particles;
}

/// 全 App 共用的飄落動畫控制器。
final moodFallControllerProvider = Provider<MoodFallController>((ref) {
  final controller = MoodFallController();
  ref.onDispose(controller.dispose);
  return controller;
});

/// 每種氛圍對應哪一種飄落效果。
extension MoodFallEffect on MoodTheme {
  FallEffectType get fallEffect {
    switch (this) {
      case MoodTheme.winter: // ❄️ 冬
      case MoodTheme.christmas: // 🎄 聖誕節
      case MoodTheme.winterBreak: // 🧣 寒假
        return FallEffectType.snow;
      case MoodTheme.autumn: // 🍁 秋
        return FallEffectType.leaves;
      case MoodTheme.spring: // 🌸 春
        return FallEffectType.petals;
      case MoodTheme.newYear: // 🧧 過年
        return FallEffectType.fireworks;
      case MoodTheme.summer: // ☀️ 夏
        return FallEffectType.splash;
      case MoodTheme.summerBreak: // 🏖️ 暑假
        return FallEffectType.treats;
      case MoodTheme.none:
        return FallEffectType.none;
    }
  }
}
